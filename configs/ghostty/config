# configs/ghostty/config — Reference documentation only.
#
# The canonical Ghostty config is managed by Home Manager via
# programs.ghostty.settings in home.nix. Home Manager writes the active config
# to ~/.config/ghostty/config on every `home-manager switch`.
#
# This file documents the settings for reference. Do not edit this file
# expecting it to take effect — edit home.nix instead.

# Launch nushell directly as the terminal shell (NOT the OS login shell).
command = /path/to/nix-store/nushell/bin/nu

# Fonts — requires JetBrainsMono Nerd Font (installed via nerd-fonts.jetbrains-mono)
font-family = JetBrainsMono Nerd Font
font-size = 13

# Theme — catppuccin-mocha is bundled with Ghostty
theme = catppuccin-mocha

# Linux / GTK window decoration
window-decoration = server

# Shell integration is handled manually via GHOSTTY_RESOURCES_DIR in config.nu
shell-integration = none
